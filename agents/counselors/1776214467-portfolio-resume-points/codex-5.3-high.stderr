              Throw Test Error
            </button>
            <button
              onClick={() => {
                Sentry.captureMessage('This is a test message from Settings page', 'info');
              }}
              className="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700"
            >
              Send Test Message
            </button>
          </div>
        </div>
      )}
    </div>
  );
}

