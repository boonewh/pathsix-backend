      headers: { Authorization: `Bearer ${token}` },
    })
      .then((res) => res.json())
      .then(setProjects)
      .catch(() => setProjects([]));
  }, [id, token]);

  if (loadError) return <p className="p-6 text-red-600">{loadError}</p>;
  if (!client) return <p className="p-6">Loading...</p>;

  return (
    <>
